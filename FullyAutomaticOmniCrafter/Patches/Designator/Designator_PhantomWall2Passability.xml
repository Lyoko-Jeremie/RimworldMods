<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 使用条件判断：如果 Structure 已经有 specialDesignatorClasses 节点，就往里面加；如果没有，就新建这个节点 -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/DesignationCategoryDef[defName="Structure"]/specialDesignatorClasses</xpath>
        <match Class="PatchOperationAdd">
            <xpath>Defs/DesignationCategoryDef[defName="Structure"]/specialDesignatorClasses</xpath>
            <value>
                <li>FullyAutomaticOmniCrafter.Designator_PhantomWall2Passability</li>
            </value>
        </match>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/DesignationCategoryDef[defName="Structure"]</xpath>
            <value>
                <specialDesignatorClasses>
                    <li>FullyAutomaticOmniCrafter.Designator_PhantomWall2Passability</li>
                </specialDesignatorClasses>
            </value>
        </nomatch>
    </Operation>
</Patch>
