<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <Defs>
        <DesignatorDropdownGroupDef>
            <defName>UltimateAutoRepair_DropdownGroup</defName>
            <!-- 这里不需要加 <label>，因为游戏会自动使用你选中的那个建筑的名称 -->
        </DesignatorDropdownGroupDef>
    </Defs>
    
    <ThingDef Name="UltimateAutoRepair" ParentName="BuildingBase">
        <defName>UltimateAutoRepair</defName>
        <label>Ultimate Auto Repair Station</label>
        <description>description</description>
        <thingClass>FullyAutomaticOmniCrafter.Building_UltimateAutoRepair</thingClass>
        
        <!-- 下拉菜单配置放在父类，子类自动继承 -->
        <designatorDropdown>UltimateAutoRepair_DropdownGroup</designatorDropdown>
        <designationCategory>OmniCrafter_Category</designationCategory> <!-- 所在的建筑栏 -->

        <graphicData>
            <texPath>Things/Building/Production/UltimateAutoRepair</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(3,3)</drawSize>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>1</pathCost>
        <blockWind>false</blockWind>
        <castEdgeShadows>false</castEdgeShadows>
        <staticSunShadowHeight>0.0</staticSunShadowHeight>
        <fillPercent>0.5</fillPercent>
        <canOverlapZones>false</canOverlapZones>
        <size>(3,3)</size>
        <costList>
            <Steel>150</Steel>
        </costList>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>
        <statBases>
            <Mass>50</Mass>
            <MaxHitPoints>999999999</MaxHitPoints>
        </statBases>
        <tickerType>Rare</tickerType>
        <building>
            <paintable>true</paintable>
        </building>
        <comps>
            <li Class="CompProperties_Flickable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>200</basePowerConsumption>
                <shortCircuitInRain>false</shortCircuitInRain>
            </li>
<!--            <li Class="CompProperties_Breakdownable"/>-->
        </comps>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <constructEffect>ConstructMetal</constructEffect>
        <repairEffect>Repair</repairEffect>
        <rotatable>false</rotatable>
        <uiIconPath>Things/Building/Production/UltimateAutoRepair</uiIconPath>
    </ThingDef>

    <ThingDef ParentName="UltimateAutoRepair">
        <defName>UltimateAutoRepair_mini</defName>
        <label>Ultimate Auto Repair Station mini</label>
        <description>description</description>
        <size>(1,1)</size>
        <graphicData>
            <drawSize>(1,1)</drawSize>
        </graphicData>
    </ThingDef>
    
