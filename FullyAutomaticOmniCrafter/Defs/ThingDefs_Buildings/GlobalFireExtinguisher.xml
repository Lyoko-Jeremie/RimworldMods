<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <DesignatorDropdownGroupDef>
        <defName>GlobalFireExtinguisher_DropdownGroup</defName>
    </DesignatorDropdownGroupDef>

    <ThingDef Name="GlobalFireExtinguisher" ParentName="BuildingBase">
        <defName>GlobalFireExtinguisher</defName>
        <label>GlobalFireExtinguisher</label>
        <description>description</description>

        <!-- 下拉菜单配置放在父类，子类自动继承 -->
        <designatorDropdown>GlobalFireExtinguisher_DropdownGroup</designatorDropdown>
        <designationCategory>OmniCrafter_Category</designationCategory> <!-- 所在的建筑栏 -->

        <graphicData>
            <texPath>Things/Building/Production/GlobalFireExtinguisher</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(3,3)</drawSize>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>

        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>1</pathCost>
        <blockWind>false</blockWind>
        <castEdgeShadows>false</castEdgeShadows>
        <staticSunShadowHeight>0.0</staticSunShadowHeight>
        <fillPercent>0.5</fillPercent>
        <canOverlapZones>false</canOverlapZones>
        <size>(3,3)</size>
        
        <costList>
            <Steel>200</Steel>
        </costList>

        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>

        <statBases>
            <Mass>50</Mass>
            <MaxHitPoints>999999999</MaxHitPoints>
        </statBases>

        <tickerType>Normal</tickerType>

        <comps>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>1500</basePowerConsumption>
                <shortCircuitInRain>true</shortCircuitInRain>
            </li>

            <li Class="FullyAutomaticOmniCrafter.CompProperties_GlobalFireExtinguisher">
                <checkIntervalTicks>60</checkIntervalTicks>
            </li>
        </comps>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <constructEffect>ConstructMetal</constructEffect>
        <repairEffect>Repair</repairEffect>
        <rotatable>false</rotatable>
        <uiIconPath>Things/Building/Production/GlobalFireExtinguisher</uiIconPath>
    </ThingDef>

    <ThingDef ParentName="GlobalFireExtinguisher">
        <defName>GlobalFireExtinguisher_mini</defName>
        <label>GlobalFireExtinguisher Portable</label>
        <description>description</description>
        <size>(1,1)</size>
        <graphicData>
            <drawSize>(1,1)</drawSize>
        </graphicData>
    </ThingDef>

