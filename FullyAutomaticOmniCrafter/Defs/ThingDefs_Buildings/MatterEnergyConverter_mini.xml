<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--
      ══════════════════════════════════════════════════════════════════════
      物质-能量转化仪 / Matter-Energy Converter
      thingClass : FullyAutomaticOmniCrafter.Building_MatterEnergyConverter
      继承        : Building_Storage（带存储过滤器 + ITab_Storage）
      功能        :
        A – 载入模式（CompTransporter 货舱 → 转化）
        B – 存储区批量模式（放在建筑格上 → 一键转化）
        C – 光标定点模式（直接点选地图上任意目标 → 即刻转化）
      ══════════════════════════════════════════════════════════════════════
    -->

    <ThingDef ParentName="BuildingBase">

        <!-- ── 基础标识 ────────────────────────────────────────────────── -->
        <defName>MatterEnergyConverter_mini</defName>
        <label>Matter-Energy Converter mini</label>
        <description>description</description>
        <thingClass>FullyAutomaticOmniCrafter.Building_MatterEnergyConverter</thingClass>

        <!-- ── 贴图（暂用 OmniCrafter 贴图占位，建议替换为专用贴图） ─── -->
        <graphicData>
            <texPath>Things/Building/Production/MatterEnergyConverter</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1,1)</drawSize>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <uiIconPath>Things/Building/Production/MatterEnergyConverter</uiIconPath>

        <!-- ── 布局 ───────────────────────────────────────────────────── -->
        <size>(1,1)</size>
        <altitudeLayer>Building</altitudeLayer>
        <passability>Standable</passability>
        <pathCost>1</pathCost>
        <fillPercent>0.5</fillPercent>
        <blockWind>false</blockWind>
        <castEdgeShadows>false</castEdgeShadows>
        <staticSunShadowHeight>0.0</staticSunShadowHeight>
        <canOverlapZones>false</canOverlapZones>
        <rotatable>false</rotatable>

        <!-- ── 表面类型（允许堆放物品供回收） ───────────────────────── -->
        <surfaceType>Item</surfaceType>

        <!-- ── 互动格 ─────────────────────────────────────────────────── -->
        <hasInteractionCell>false</hasInteractionCell>
<!--        <interactionCellOffset>(0,0,-2)</interactionCellOffset>-->

        <!-- ── 属性基础值 ─────────────────────────────────────────────── -->
        <statBases>
            <MaxHitPoints>1</MaxHitPoints>
<!--            <WorkToBuild>1800</WorkToBuild>-->
            <Mass>50</Mass>
<!--            <Flammability>0.5</Flammability>-->
<!--            <Beauty>-15</Beauty>-->
        </statBases>

        <!-- ── 建造成本 ───────────────────────────────────────────────── -->
        <costList>
            <Steel>50</Steel>
<!--            <Plasteel>150</Plasteel>-->
<!--            <ComponentSpacer>8</ComponentSpacer>-->
<!--            <Gold>20</Gold>-->
        </costList>

        <!-- ── 可打包为小物件带走 ─────────────────────────────────────── -->
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>

        <!-- ── Tick 类型 ──────────────────────────────────────────────── -->
        <tickerType>Normal</tickerType>

        <!-- ── 建筑属性 ───────────────────────────────────────────────── -->
        <building>
            <paintable>true</paintable>
            <destroySound>BuildingDestroyed_Metal_Big</destroySound>

            <!--
              必须指定 blueprintClass = Blueprint_Storage，否则默认使用 Blueprint_Build，
              导致 Frame 的 storageSettings 为 null，Frame.CompleteConstruction 时
              调用 storageSettings.CopyFrom(null) 引发 NullReferenceException。
            -->
            <blueprintClass>Blueprint_Storage</blueprintClass>

            <!--
              fixedStorageSettings：允许玩家将任意可存储物品放置于此。
              玩家可在 "存储" 选项卡中自行缩小范围。
            -->
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Root</li>
                    </categories>
                </filter>
            </fixedStorageSettings>

            <!--
              defaultStorageSettings：默认优先级 Low，防止殖民者
              自动将全营地物资搬来销毁。玩家可手动调整。
            -->
            <!--
              defaultStorageSettings：默认优先级 Low，过滤器设为空白，
              避免首次建造时殖民者自动搬运任何物品进来意外销毁。
              玩家可在存储选项卡中手动启用所需类别。
            -->
            <defaultStorageSettings>
                <priority>Low</priority>
                <filter>
                    <allowedDefs />
                </filter>
            </defaultStorageSettings>
        </building>

        <!-- ── 存储选项卡（来自 Building_Storage） ───────────────────── -->
        <inspectorTabs>
            <li>ITab_Storage</li>
            <li>ITab_ContentsTransporter</li>
        </inspectorTabs>

        <!-- ── 组件 ───────────────────────────────────────────────────── -->
        <comps>

            <!-- 开关控制，允许玩家手动断开 -->
            <li Class="CompProperties_Flickable"/>

            <!-- 机械故障 -->
            <li Class="CompProperties_Breakdownable"/>

            <!--
              电力接入组件：
              转化仪接入电网，维持运转消耗 500 W。
              C# 代码通过此 comp 的 PowerNet 向电网中的电池注入电能。
            -->
            <li Class="CompProperties_Battery">
                <compClass>FullyAutomaticOmniCrafter.CompMatterEnergyConverterBattery</compClass>
                <!-- 基础最大容量，代码里设置的 BaseCapacity 是1000，这里最好匹配 -->
                <storedEnergyMax>1000</storedEnergyMax>
                <shortCircuitInRain>false</shortCircuitInRain>
                <transmitsPower>true</transmitsPower>
            </li>

            <!--
              载具组件（方式 A）：
              允许玩家手动装载物品到货舱，再通过 Gizmo 一键转化。
              canChangeAssignedThingsAfterStarting=true 允许在任意时刻追加物品。
            -->
            <li Class="CompProperties_Transporter">
                <restEffectiveness>0</restEffectiveness>
                <massCapacity>999999</massCapacity>
                <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
            </li>

        </comps>

        <!-- ── 地形要求 ───────────────────────────────────────────────── -->
        <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>

        <!-- ── 建造分类（生产标签页） ───────────────────────────────── -->
        <designationCategory>Production</designationCategory>

        <!-- ── 研究前提 ───────────────────────────────────────────────── -->
        <!--    <researchPrerequisites>-->
        <!--      <li>Spaceflight</li>-->
        <!--    </researchPrerequisites>-->

        <!-- ── 建造 / 修理音效 ────────────────────────────────────────── -->
        <constructEffect>ConstructMetal</constructEffect>
        <repairEffect>Repair</repairEffect>

    </ThingDef>

</Defs>

