    <ThingDef Name="OmniPhantomWall_Animal_" ParentName="OmniPhantomWallBase">
        <defName>OmniPhantomWall_Animal_</defName>
        <label>OmniPhantomWall_Animal_</label>
        <description>description</description>
        
        <graphicData>
<!--            <texPath>Things/Building/Linked/Wall/OmniPhantomWall_Animal</texPath>-->
