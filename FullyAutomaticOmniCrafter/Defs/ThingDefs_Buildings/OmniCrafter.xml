<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <DesignatorDropdownGroupDef>
        <defName>OmniCrafter_DropdownGroup</defName>
    </DesignatorDropdownGroupDef>
    
    <ThingDef Name="OmniCrafter" ParentName="BuildingBase">
        <defName>OmniCrafter</defName>
        <label>Omni Crafter</label>
        <description>Get Anything From Nothing! \n\n Archotech Technology! Boys!</description>
        <thingClass>FullyAutomaticOmniCrafter.Building_OmniCrafter</thingClass>
        
        <!-- 下拉菜单配置放在父类，子类自动继承 -->
        <designatorDropdown>OmniCrafter_DropdownGroup</designatorDropdown>
        <designationCategory>OmniCrafter_Category</designationCategory> <!-- 所在的建筑栏 -->

        <graphicData>
            <texPath>Things/Building/Production/OmniCrafter2</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(5,5)</drawSize>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>1</pathCost>
        <blockWind>false</blockWind>
        <castEdgeShadows>false</castEdgeShadows>
        <staticSunShadowHeight>0.0</staticSunShadowHeight>
        <fillPercent>0.5</fillPercent>
        <canOverlapZones>false</canOverlapZones>
        <size>(5,5)</size>
        <costList>
            <Steel>200</Steel>
            <!--            <ComponentIndustrial>8</ComponentIndustrial>-->
            <!--            <ComponentSpacer>4</ComponentSpacer>-->
        </costList>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>
        <statBases>
            <Mass>50</Mass>
            <MaxHitPoints>999999999</MaxHitPoints>
            <Flammability>0</Flammability> <!-- 不可燃 -->
            <Beauty>100</Beauty>
        </statBases>
        <tickerType>Rare</tickerType>
        <building>
            <paintable>true</paintable>
        </building>
        <comps>
            <li Class="CompProperties_Flickable"/>
<!--            <li Class="CompProperties_Breakdownable"/>-->

            <!-- 无限电池核心逻辑组件 -->
            <li Class="CompProperties_Battery">
                <!-- 重点：指定使用我们刚写的 C# 电池类 -->
                <compClass>FullyAutomaticOmniCrafter.CompOmniCrafterSmartInfiniteBattery</compClass>
                <!-- 基础最大容量，代码里设置的 BaseCapacity 是1000，这里最好匹配 -->
                <storedEnergyMax>1000</storedEnergyMax>
                <!-- 转化效率1.0 (100%) -->
                <efficiency>1.0</efficiency>
                <shortCircuitInRain>false</shortCircuitInRain>
                <transmitsPower>true</transmitsPower>
            </li>

            <!--            <li Class="CompProperties_Power">-->
            <!--                <compClass>CompPowerTrader</compClass>-->
            <!--                <basePowerConsumption>1000</basePowerConsumption>-->
            <!--                <shortCircuitInRain>false</shortCircuitInRain>-->
            <!--            </li>-->

<!--            <li Class="FullyAutomaticOmniCrafter.CompProperties_BreathingLight">-->
<!--                <texPath>Things/Building/Production/OmniCrafter2l</texPath>-->
<!--                <color>(105.65, 225.9, 243.25)</color>-->
<!--                <speed>5.0</speed>-->
<!--                <minAlpha>0.1</minAlpha>-->
<!--                <maxAlpha>1.0</maxAlpha>-->
<!--            </li>-->

            <li Class="FullyAutomaticOmniCrafter.CompProperties_InstantResearch"/>

        </comps>
        <!--        <interactionCellOffset>(0,0,-1)</interactionCellOffset>-->
        <!--        <hasInteractionCell>true</hasInteractionCell>-->
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <!--    <researchPrerequisites>-->
        <!--      <li>Fabrication</li>-->
        <!--    </researchPrerequisites>-->
        <constructEffect>ConstructMetal</constructEffect>
        <repairEffect>Repair</repairEffect>
        <rotatable>false</rotatable>
        <uiIconPath>Things/Building/Production/OmniCrafter2</uiIconPath>
    </ThingDef>

    <ThingDef ParentName="OmniCrafter">
        <defName>OmniCrafter_mini</defName>
        <label>Omni Crafter mini</label>
        <description>Get Anything From Nothing! \n\n Archotech Technology! Boys!</description>
        <graphicData>
            <drawSize>(1,1)</drawSize>
        </graphicData>
        <size>(1,1)</size>
    </ThingDef>

