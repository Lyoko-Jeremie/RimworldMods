<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!--  检查是否存在并为基类 HDH_Hydroponics_base 的comps添加 <li Class="FullyAutoHydroponicsThingComp.CompProperties_No_FullyAutoHydroponics"/>  -->

    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[@Name="HDH_Hydroponics_base"]</xpath>

        <match Class="PatchOperationConditional">
            <xpath>Defs/ThingDef[@Name="HDH_Hydroponics_base"]/comps</xpath>

            <match Class="PatchOperationAdd">
                <xpath>Defs/ThingDef[@Name="HDH_Hydroponics_base"]/comps</xpath>
                <value>
                    <li Class="FullyAutoHydroponicsThingComp.CompProperties_No_FullyAutoHydroponics"/>
                </value>
            </match>

            <nomatch Class="PatchOperationAdd">
                <xpath>Defs/ThingDef[@Name="HDH_Hydroponics_base"]</xpath>
                <value>
                    <comps>
                        <li Class="FullyAutoHydroponicsThingComp.CompProperties_No_FullyAutoHydroponics"/>
                    </comps>
                </value>
            </nomatch>

        </match>
    </Operation>

</Patch>
