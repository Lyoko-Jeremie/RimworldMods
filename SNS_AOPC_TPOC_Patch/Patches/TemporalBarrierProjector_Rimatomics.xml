<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <Operation Class="PatchOperationFindMod">
    <mods>
<!--      <name>Dubs Rimatomics</name>-->
      <li>Dubs Rimatomics</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

        <li Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]/comps</xpath>

          <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]</xpath>
            <value>
              <comps>
                <li Class="CompProperties_CauseHediff_Apparel">
                  <hediff>SNS_TemporalBarrier_RadClear</hediff>
                  <hediffSeverity>1.0</hediffSeverity>
                </li>
              </comps>
            </value>
          </nomatch>

          <match Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]/comps</xpath>
            <value>
              <li Class="CompProperties_CauseHediff_Apparel">
                <hediff>SNS_TemporalBarrier_RadClear</hediff>
                <hediffSeverity>1.0</hediffSeverity>
              </li>
            </value>
          </match>
        </li>

        <li Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]/statBases</xpath>

          <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]</xpath>
            <value>
              <statBases>
                <Radiation>0.0</Radiation>
              </statBases>
            </value>
          </nomatch>

          <match Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="SNS_CE_TemporalBarrierProjector"]/statBases</xpath>
            <value>
              <Radiation>0.0</Radiation>
            </value>
          </match>
        </li>

      </operations>
    </match>
  </Operation>

</Patch>
